var QS={qs:[],cur:0,score:0,answered:false,sel:null};
function getQs(subj,grade){
  var gm=QB[subj]||{},pool=[];
  if(grade&&gm[grade])pool=gm[grade];
  else Object.values(gm).forEach(function(a){pool=pool.concat(a);});
  return pool.length?pool:[{q:'What is 2+2?',o:['4','3','5','6'],a:0,e:'2+2=4.'}];
}
function loadQuiz(){
  var type=(document.getElementById('qType')||{}).value||'mcq';
  document.getElementById('quizScoreBox').style.display='none';
  if(type==='graph'){renderGQMode();return;}
  if(type==='fill'){renderFillMode();return;}
  var subj=(document.getElementById('qSubj')||{}).value||'Mathematics';
  var grade=(document.getElementById('qGrade')||{}).value||(CU&&CU.grade)||'Grade 9';
  var pool=[].concat(getQs(subj,grade)).sort(function(){return Math.random()-.5;}).slice(0,10);
  QS={qs:pool,cur:0,score:0,answered:false,sel:null};
  renderQ();
}
function renderQ(){
  var qa=document.getElementById('quizArea');
  if(QS.cur>=QS.qs.length){showScore();return;}
  var q=QS.qs[QS.cur],pct=(QS.cur/QS.qs.length)*100;
  qa.innerHTML='<div class="qprog"><div class="qp-bar"><div class="qp-fill" style="width:'+pct+'%"></div></div><div class="qp-txt">'+(QS.cur+1)+'/'+QS.qs.length+'</div><span class="bdg bv">Score: '+QS.score+'</span></div>'
    +'<div class="quiz-box"><div class="quiz-q">'+q.q+'</div>'
    +'<div class="quiz-opts">'+q.o.map(function(o,i){return '<button class="qopt" onclick="selOpt('+i+')" data-i="'+i+'"><span class="opt-l">'+'ABCD'[i]+'</span>'+o+'</button>';}).join('')+'</div>'
    +'<div class="quiz-exp" id="qExp">💡 <strong>Explanation:</strong> '+(q.e||'')+'</div>'
    +'<div class="quiz-acts"><button class="qbtn qbtn-v" id="qCheck" onclick="checkAns()" style="display:none">Submit</button><button class="qbtn qbtn-b" id="qNext" onclick="nextQ()" style="display:none">Next →</button><button class="qbtn qbtn-g" onclick="loadQuiz()">Restart</button></div>'
    +'</div>';
  QS.answered=false;QS.sel=null;
}
function selOpt(i){
  if(QS.answered)return;QS.sel=i;
  document.querySelectorAll('.qopt').forEach(function(b,j){b.classList.toggle('sel',j===i);});
  document.getElementById('qCheck').style.display='inline-flex';
}
function checkAns(){
  if(QS.sel===null||QS.answered)return;QS.answered=true;
  var cor=QS.qs[QS.cur].a;
  document.querySelectorAll('.qopt').forEach(function(b,i){b.classList.add('dis');if(i===cor)b.classList.add('cor');else if(i===QS.sel&&QS.sel!==cor)b.classList.add('wrg');});
  if(QS.sel===cor)QS.score++;
  document.getElementById('qExp').classList.add('show');
  document.getElementById('qCheck').style.display='none';
  document.getElementById('qNext').style.display='inline-flex';
}
