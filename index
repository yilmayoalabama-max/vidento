async function setLang(code){
  currentLang=code;
  try{localStorage.setItem('vident_lang',code);}catch(e){}
  document.querySelectorAll('.lang-item').forEach(function(el){el.classList.toggle('active',el.dataset.lang===code);});
  document.getElementById('langPanel').classList.remove('open');

  if(code==='en'){
    applyTranslations(I18N);
    document.documentElement.lang='en';
    document.documentElement.dir='ltr';
    return;
  }

  var rtlCodes=['ar','he','ur','fa','ps','sd','ug'];
  document.documentElement.dir=rtlCodes.indexOf(code)!==-1?'rtl':'ltr';
  document.documentElement.lang=code;

  var fab=document.querySelector('.lang-btn');
  fab.innerHTML='⏳';
  fab.style.opacity='0.7';

  // Use baked-in translations
  if(BAKED_TRANSLATIONS && BAKED_TRANSLATIONS[code]){
    // Merge: baked translation overrides I18N defaults, keep any missing keys as English
    var merged = Object.assign({}, I18N, BAKED_TRANSLATIONS[code]);
    applyTranslations(merged);
  } else {
    applyTranslations(I18N);
  }

  fab.innerHTML='🌐';
  fab.style.opacity='1';
}

function applyTranslations(t){
  document.querySelectorAll('[data-i18n]').forEach(function(el){
    var key=el.getAttribute('data-i18n');
    if(t[key]!==undefined){
      if(el.tagName==='INPUT'||el.tagName==='TEXTAREA'){
        if(el.placeholder)el.placeholder=t[key];
      }else{
        el.innerHTML=t[key];
      }
    }
  });
}

// Init on load — wait for DOM so #langList exists
document.addEventListener('DOMContentLoaded',function(){
  buildLangList();
  try{
    var saved=localStorage.getItem('vident_lang');
    if(saved&&saved!=='en')setLang(saved);
  }catch(e){}
});

</script>

