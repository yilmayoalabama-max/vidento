var gFns=[];
function initGraph(){
  var cv=document.getElementById('gCanvas');if(!cv)return;
  cv.width=cv.offsetWidth||600;
  renderGraph();
}
function setFn(fn){var i=document.getElementById('fnInp');if(i)i.value=fn;plotFn();}
function clearGraphs(){gFns=[];renderGraph();updateGList();}
function plotFn(){
  var fn=(document.getElementById('fnInp')||{}).value||'';fn=fn.trim();if(!fn)return;
  var color=(document.getElementById('gColor')||{}).value||'#4a6fa5';
  gFns.push({fn:fn,color:color});renderGraph();updateGList();
}
function evalFn(fn,x){
  try{
    var e=fn.replace(/\^/g,'**').replace(/\bsin\b/g,'Math.sin').replace(/\bcos\b/g,'Math.cos').replace(/\btan\b/g,'Math.tan').replace(/\bsqrt\b/g,'Math.sqrt').replace(/\blog\b/g,'Math.log10').replace(/\babs\b/g,'Math.abs').replace(/\bpi\b/gi,'Math.PI');
    return (new Function('x','return ('+e+')'))(x);
  }catch(e){return NaN;}
}
function renderGraph(){
  var cv=document.getElementById('gCanvas');if(!cv)return;
  cv.width=cv.offsetWidth||660;
  var ctx=cv.getContext('2d'),W=cv.width,H=cv.height||340;cv.height=H;
  ctx.fillStyle='#060610';ctx.fillRect(0,0,W,H);
  var sc=44,cx=W/2,cy=H/2;
  ctx.strokeStyle='rgba(0,0,0,0.03)';ctx.lineWidth=1;
  for(var x=0;x<W;x+=sc){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(var y=0;y<H;y+=sc){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
  ctx.strokeStyle='rgba(255,255,255,0.2)';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(0,cy);ctx.lineTo(W,cy);ctx.stroke();
  ctx.beginPath();ctx.moveTo(cx,0);ctx.lineTo(cx,H);ctx.stroke();
  ctx.fillStyle='rgba(255,255,255,0.28)';ctx.font='10px DM Sans';
  for(var i=-6;i<=6;i++){if(i!==0){ctx.fillText(i,cx+i*sc-3,cy+13);ctx.fillText(-i,cx-14,cy-i*sc+4);}}
  ctx.fillStyle='rgba(255,255,255,0.35)';ctx.fillText('x',W-10,cy-8);ctx.fillText('y',cx+7,10);ctx.fillText('0',cx+4,cy+12);
  gFns.forEach(function(d){
    ctx.strokeStyle=d.color;ctx.lineWidth=2.5;ctx.beginPath();var started=false;
    for(var px=0;px<W;px++){
      var xv=(px-cx)/sc,yv=evalFn(d.fn,xv);
      if(isFinite(yv)&&!isNaN(yv)&&Math.abs(yv)<12){
        var pyv=cy-yv*sc;
        if(!started){ctx.moveTo(px,pyv);started=true;}else ctx.lineTo(px,pyv);
      }else started=false;
    }
    ctx.stroke();
    // mark x-intercepts
    ctx.fillStyle=d.color;
    for(var px=1;px<W-1;px++){
      var xv=(px-cx)/sc,y1=evalFn(d.fn,xv),y2=evalFn(d.fn,(px-1-cx)/sc);
      if(isFinite(y1)&&isFinite(y2)&&((y1>0&&y2<0)||(y1<0&&y2>0))){ctx.beginPath();ctx.arc(px,cy,4,0,Math.PI*2);ctx.fill();}
    }
  });
}
function updateGList(){
  var el=document.getElementById('gFnList');if(!el)return;
  el.innerHTML=gFns.map(function(d,i){return '<span style="background:'+d.color+'22;border:1px solid '+d.color+'44;border-radius:6px;padding:4px 10px;font-size:11px;color:'+d.color+';display:inline-flex;align-items:center;gap:6px;">y='+d.fn+' <button style="border:none;background:none;color:'+d.color+';font-size:10px;font-weight:700;" onclick="gFns.splice('+i+',1);renderGraph();updateGList()">✕</button></span>';}).join('');
}

