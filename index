var currentLang='en';

function toggleLangPanel(){
  var p=document.getElementById('langPanel');
  p.classList.toggle('open');
  if(p.classList.contains('open'))document.getElementById('langSearch').focus();
}

// Close panel on outside click
document.addEventListener('click',function(e){
  var fab=document.getElementById('langFab');
  if(fab&&!fab.contains(e.target)){document.getElementById('langPanel').classList.remove('open');}
});

function buildLangList(){
  var el=document.getElementById('langList');
  el.innerHTML=LANGS.map(function(l){
    return '<button class="lang-item'+(l.code===currentLang?' active':'')+'" data-lang="'+l.code+'" onclick="setLang(\''+l.code+'\')"><span class="lang-item-flag">'+l.flag+'</span><span class="lang-item-name">'+l.name+'</span><span class="lang-item-native">'+l.native+'</span></button>';
  }).join('');
}

function filterLangs(q){
  q=q.toLowerCase();
  document.querySelectorAll('.lang-item').forEach(function(el){
    var name=el.querySelector('.lang-item-name').textContent.toLowerCase();
    var nat=el.querySelector('.lang-item-native').textContent.toLowerCase();
    el.style.display=(name.includes(q)||nat.includes(q))?'':'none';
  });
}

