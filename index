  var db=gDB();
  if(db.users.some(function(u){return u.email.toLowerCase()===em;})){if(err){err.textContent='This email already exists.';err.style.display='block';}return;}
  var sc={Mathematics:Math.floor(48+Math.random()*46),Science:Math.floor(48+Math.random()*46),English:Math.floor(48+Math.random()*46),History:Math.floor(48+Math.random()*46),Geography:Math.floor(48+Math.random()*46)};
  var avg=Math.round(Object.values(sc).reduce(function(a,b){return a+b;},0)/5);
