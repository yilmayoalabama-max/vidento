async function sendAI(ch){
  var cfg=aiCfg[ch];if(!cfg)return;
  var inp=document.getElementById(cfg.inp);
  var text=inp?inp.value.trim():'';
  if(!text)return;inp.value='';
  addMsg(cfg.msgs,'user',text);
  aiHistories[ch].push({role:'user',content:text});
  showTyping(cfg.msgs);
  var isT=ch==='t'||ch==='t2';
  var db=gDB();
  var myStu=db.users.filter(function(u){return u.role==='student'&&u.school===(CU&&CU.school);});
  var curr=(db.curriculum&&db.curriculum[CU&&CU.school])||{};
  var currStr=Object.keys(curr).length?Object.keys(curr).slice(0,6).join(', '):'standard curriculum';
  var user=CU||{name:'Student',scores:{},grade:'Grade 9',mistakes:[]};
  var sys=isT
    ?'You are Vident AI, teacher assistant at '+user.school+'. Students: '+myStu.map(function(s){return s.name+'('+s.avg+'%)';}).join(', ')+'. Averages: Maths 65%, Science 72%, English 78%. School curriculum: '+currStr+'. Common mistakes: quadratic second root (6 students), BODMAS (5), photosynthesis confusion (5). Be concise, data-driven. Use **bold** for emphasis. Max 150 words.'
    :'You are Vident AI, personal tutor for '+user.name+' ('+user.grade+'). Scores: '+Object.entries(user.scores||{}).map(function(e){return e[0]+':'+e[1]+'%';}).join(', ')+'. Mistakes: '+(user.mistakes||[]).join(', ')||'none'+'. School curriculum: '+currStr+'. Be encouraging, give numbered steps, use **bold** for key terms/formulas. When explaining concepts, go step by step. Max 160 words.';
  try{
    var res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:300,system:sys,messages:aiHistories[ch]})});
    var data=await res.json();
    rmTyping(cfg.msgs);
    var reply=(data.content&&data.content[0]&&data.content[0].text)||"I'm having trouble connecting. Try again shortly.";
    aiHistories[ch].push({role:'assistant',content:reply});
    addMsg(cfg.msgs,'ai',reply);
  }catch(e){
    rmTyping(cfg.msgs);
    addMsg(cfg.msgs,'ai',"Connection issue. Check your internet. Meanwhile, browse **AI Notes** for personalised revision!");
  }
}

